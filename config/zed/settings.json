{
    "icon_theme": "Material Icon Theme",
    "ui_font_family": "Noto Sans",
    "buffer_font_family": "IosevkaTerm Nerd Font Mono",
    "ui_font_size": 18,
    "buffer_font_size": 18,
    "preferred_line_length": 100,
    "tab_size": 4,
    "theme": {
        "mode": "system",
        "light": "Noctalia Light Transparent",
        "dark": "Noctalia Dark",
    },
    "tabs": {
        "file_icons": true,
        "git_status": true,
    },
    "tab_bar": {
        "show": true,
        "show_nav_history_buttons": false,
    },
    "project_panel": {
        "indent_size": 16,
    },
}
